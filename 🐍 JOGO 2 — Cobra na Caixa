#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <string.h>

#define NUM_CAIXAS 5
#define NUM_NOMES 7

void linha(){
    printf("\n====================================\n\n");
}

int main(){

    char *nomes[NUM_NOMES]={"Paulo","Cleber","Banna","Alycia","Arthur","Paula","Marcello"};
    char jogadores[2][50];

    int botao,cobra;
    int caixasAbertas[NUM_CAIXAS];

    int turno;
    int caixa;

    int i,j;
    int escolha;

    srand(time(NULL));

    printf("COBRA NA CAIXA\n");
    linha();

    for(i=0;i<NUM_CAIXAS;i++)
        caixasAbertas[i]=0;

    for(i=0;i<2;i++){

        printf("Jogador %d escolha seu nome:  \n\n",i+1);

        for(j=0;j<NUM_NOMES;j++){
            printf("%d - %s\n",j+1,nomes[j]);
        }

        scanf("%d",&escolha);
        strcpy(jogadores[i],nomes[escolha-1]);
        printf("\n");
    }

    botao=rand()%NUM_CAIXAS;

    do{
        cobra=rand()%NUM_CAIXAS;
    }while(cobra==botao);

    turno=rand()%2;

    while(1){

        printf("\n%s escolha uma caixa (1-5): ",jogadores[turno]);

        scanf("%d",&caixa);
        caixa--;

        if(caixa<0 || caixa>=NUM_CAIXAS){
            printf("Caixa invalida\n");
            continue;
        }

        if(caixasAbertas[caixa]){
            printf("Essa caixa ja foi aberta\n");
            continue;
        }

        caixasAbertas[caixa]=1;

        if(caixa==botao){

            printf("\n%s encontrou o BOTAO e venceu!\n",jogadores[turno]);
            break;

        }else if(caixa==cobra){

            printf("\n%s encontrou a COBRA e perdeu!\n",jogadores[turno]);
            break;

        }else{

            printf("\nCaixa vazia!\n");
        }

        turno=1-turno;
    }

    return 0;
}
