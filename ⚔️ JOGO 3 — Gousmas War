#include <stdio.h>
#include <stdlib.h>

#define MAX_GOUSMAS 2
#define MAX_FURIA 5

typedef struct{
    int furia;
    int ativa;
}Gousma;

void linha(){
    printf("\n====================================\n\n");
}

int main(){

    Gousma jogadores[2][MAX_GOUSMAS];

    int turno;
    int i;

    int acao,a,d;
    int origem,destino,valor;

    int vitorias1 = 0;
    int vitorias2 = 0;

    int jogar = 1;

    while(jogar){

        turno = 0;

        /* inicializa gousmas */

        for(i=0;i<MAX_GOUSMAS;i++){

            jogadores[0][i].furia = 1;
            jogadores[1][i].furia = 1;

            jogadores[0][i].ativa = 1;
            jogadores[1][i].ativa = 1;
        }

        while(1){

            system("cls");

            printf("GOUSMAS WAR\n");
            linha();

            printf("PLACAR\n");
            printf("Jogador 1: %d vitorias\n",vitorias1);
            printf("Jogador 2: %d vitorias\n",vitorias2);

            linha();

            printf("Jogador 1\n");

            for(i=0;i<MAX_GOUSMAS;i++){

                if(jogadores[0][i].ativa)
                    printf("Gousma %d -> Furia %d\n",i+1,jogadores[0][i].furia);
                else
                    printf("Gousma %d -> Destruida\n",i+1);
            }

            printf("\nJogador 2\n");

            for(i=0;i<MAX_GOUSMAS;i++){

                if(jogadores[1][i].ativa)
                    printf("Gousma %d -> Furia %d\n",i+1,jogadores[1][i].furia);
                else
                    printf("Gousma %d -> Destruida\n",i+1);
            }

            linha();

            printf("Turno Jogador %d\n\n",turno+1);

            printf("1 - Atacar\n");
            printf("2 - Dividir\n");

            printf("Escolha: ");
            scanf("%d",&acao);

            if(acao==1){

                printf("Sua gousma (1-2): ");
                scanf("%d",&a);
                a--;

                printf("Gousma inimiga (1-2): ");
                scanf("%d",&d);
                d--;

                if(a<0 || a>=MAX_GOUSMAS || d<0 || d>=MAX_GOUSMAS){

                    printf("Escolha invalida!\n");
                    system("pause");
                    continue;
                }

                if(!jogadores[turno][a].ativa){

                    printf("Sua gousma esta destruida!\n");
                    system("pause");
                    continue;
                }

                jogadores[1-turno][d].furia += jogadores[turno][a].furia;

                if(jogadores[1-turno][d].furia > MAX_FURIA){

                    jogadores[1-turno][d].ativa = 0;

                    printf("Gousma inimiga destruida!\n");
                    system("pause");
                }
            }

            else if(acao==2){

                printf("Origem (1-2): ");
                scanf("%d",&origem);
                origem--;

                printf("Destino (1-2): ");
                scanf("%d",&destino);
                destino--;

                printf("Furia transferida: ");
                scanf("%d",&valor);

                if(origem<0 || origem>=MAX_GOUSMAS || destino<0 || destino>=MAX_GOUSMAS){

                    printf("Escolha invalida!\n");
                    system("pause");
                    continue;
                }

                if(!jogadores[turno][origem].ativa){

                    printf("A gousma de origem esta destruida!\n");
                    system("pause");
                    continue;
                }

                if(valor < 1 || valor >= jogadores[turno][origem].furia){

                    printf("Transferencia invalida!\n");
                    system("pause");
                    continue;
                }

                jogadores[turno][origem].furia -= valor;
                jogadores[turno][destino].furia += valor;

                jogadores[turno][destino].ativa = 1;

                if(jogadores[turno][destino].furia > MAX_FURIA){

                    jogadores[turno][destino].ativa = 0;

                    printf("Sua gousma foi destruida por excesso de furia!\n");
                    system("pause");
                }
            }

            else{

                printf("Opcao invalida!\n");
                system("pause");
                continue;
            }

            /* verifica vencedor */

            int ativas1 = 0;
            int ativas2 = 0;

            for(i=0;i<MAX_GOUSMAS;i++){

                if(jogadores[0][i].ativa) ativas1++;
                if(jogadores[1][i].ativa) ativas2++;
            }

            if(ativas1==0){

                printf("\nJogador 2 venceu!\n");
                vitorias2++;
                break;
            }

            if(ativas2==0){

                printf("\nJogador 1 venceu!\n");
                vitorias1++;
                break;
            }

            turno = 1 - turno;
        }

        linha();

        printf("1 - Jogar novamente\n");
        printf("0 - Sair\n");

        scanf("%d",&jogar);
    }

    return 0;
}
