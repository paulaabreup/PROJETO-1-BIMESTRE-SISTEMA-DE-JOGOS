void quizLupin(){

    struct Pergunta{
        char pergunta[200];
        char opcoes[4][100];
        char resposta;
    };

    struct Pergunta quiz[TOTAL_PERGUNTAS]={

    {"Qual e o nome do protagonista da serie Lupin?",
    {"a) Assane Diop","b) Arsene Lupin","c) Benjamin Ferel","d) Hubert Pellegrini"},'a'},

    {"Em qual cidade a historia acontece?",
    {"a) Londres","b) Paris","c) Roma","d) Madrid"},'b'},

    {"Quem escreveu Arsene Lupin?",
    {"a) Victor Hugo","b) Alexandre Dumas","c) Maurice Leblanc","d) Emile Zola"},'c'},

    {"Qual objeto Assane tenta recuperar no inicio da serie?",
    {"a) Um colar","b) Um anel","c) Um diamante","d) Um quadro"},'a'},

    {"Qual e o nome do pai de Assane?",
    {"a) Mamadou","b) Babakar","c) Karim","d) Idris"},'b'}
    };

    int i,j,pontos=0;
    char resp;

    system("cls");

    printf("QUIZ DA SERIE LUPIN\n");
    linha();

    for(i=0;i<TOTAL_PERGUNTAS;i++){

        printf("%d) %s\n\n",i+1,quiz[i].pergunta);

        for(j=0;j<4;j++){
            printf("%s\n",quiz[i].opcoes[j]);
        }

        printf("\nResposta: ");
        scanf(" %c",&resp);

        if(resp==quiz[i].resposta || resp==quiz[i].resposta-32){
            printf("\nCorreto!\n");
            pontos++;
        }else{
            printf("\nErrado! Resposta correta: %c\n",quiz[i].resposta);
        }

        system("pause");
        system("cls");
    }

    printf("Voce acertou %d de %d perguntas!\n",pontos,TOTAL_PERGUNTAS);
}









typedef struct{
    int furia;
    int ativa;
}Gousma;

void gousmasWar(){

    Gousma jogadores[2][MAX_GOUSMAS];
    int turno=0,i;
    int acao,a,d;
    int origem,destino,valor;

    for(i=0;i<MAX_GOUSMAS;i++){

        jogadores[0][i].furia=1;
        jogadores[1][i].furia=1;

        jogadores[0][i].ativa=1;
        jogadores[1][i].ativa=1;
    }

    while(1){

        system("cls");

        printf("GOUSMAS WAR\n");
        linha();

        printf("Jogador 1\n");

        for(i=0;i<MAX_GOUSMAS;i++){

            if(jogadores[0][i].ativa)
            printf("Gousma %d -> Furia %d\n",i+1,jogadores[0][i].furia);
            else
            printf("Gousma %d -> Destruida\n",i+1);
        }

        printf("\nJogador 2\n");

        for(i=0;i<MAX_GOUSMAS;i++){

            if(jogadores[1][i].ativa)
            printf("Gousma %d -> Furia %d\n",i+1,jogadores[1][i].furia);
            else
            printf("Gousma %d -> Destruida\n",i+1);
        }

        linha();

        printf("Turno Jogador %d\n",turno+1);

        printf("1 - Atacar\n");
        printf("2 - Dividir\n");

        scanf("%d",&acao);

        if(acao==1){

            printf("Sua gousma: ");
            scanf("%d",&a);
            a--;

            printf("Gousma inimiga: ");
            scanf("%d",&d);
            d--;

            jogadores[1-turno][d].furia+=jogadores[turno][a].furia;

            if(jogadores[1-turno][d].furia>MAX_FURIA){

                jogadores[1-turno][d].ativa=0;
                printf("Gousma destruida!\n");
                system("pause");
            }
        }

        if(acao==2){

            printf("Origem: ");
            scanf("%d",&origem);
            origem--;

            printf("Destino: ");
            scanf("%d",&destino);
            destino--;

            printf("Furia transferida: ");
            scanf("%d",&valor);

            jogadores[turno][origem].furia-=valor;
            jogadores[turno][destino].furia+=valor;
        }

        int ativas1=0,ativas2=0;

        for(i=0;i<MAX_GOUSMAS;i++){

            if(jogadores[0][i].ativa)ativas1++;
            if(jogadores[1][i].ativa)ativas2++;
        }

        if(ativas1==0){

            printf("Jogador 2 venceu!\n");
            break;
        }

        if(ativas2==0){

            printf("Jogador 1 venceu!\n");
            break;
        }

        turno=1-turno;
    }
}









void cobraNaCaixa(){

    char *nomes[NUM_NOMES]={"Paulo","Cleber","Banna","Alycia","Arthur","Paula","Marcello"};
    char jogadores[2][50];

    int botao,cobra;
    int caixasAbertas[NUM_CAIXAS];

    int turno;
    int caixa;

    int i,j,escolha;

    srand(time(NULL));

    system("cls");

    printf("COBRA NA CAIXA\n");
    linha();

    for(i=0;i<NUM_CAIXAS;i++)
        caixasAbertas[i]=0;

    for(i=0;i<2;i++){

        printf("Jogador %d escolha nome\n",i+1);

        for(j=0;j<NUM_NOMES;j++)
        printf("%d - %s\n",j+1,nomes[j]);

        scanf("%d",&escolha);
        strcpy(jogadores[i],nomes[escolha-1]);
    }

    botao=rand()%NUM_CAIXAS;

    do{
        cobra=rand()%NUM_CAIXAS;
    }while(cobra==botao);

    turno=rand()%2;

    while(1){

        printf("\n%s escolha caixa (1-5): ",jogadores[turno]);
        scanf("%d",&caixa);
        caixa--;

        if(caixa==botao){

            printf("%s encontrou o BOTAO e venceu!\n",jogadores[turno]);
            break;
        }

        else if(caixa==cobra){

            printf("%s encontrou a COBRA e perdeu!\n",jogadores[turno]);
            break;
        }

        else{

            printf("Caixa vazia!\n");
        }

        turno=1-turno;
    }
}









